      "cookedHtml": "<pre><code class=\"lang-auto\">{\n  \"data\": {\n    \"complexity\": {\n      \"before\": 10000000,\n      \"reset_in_x_seconds\": 60,\n      \"after\": 9999977\n    },\n    \"boards\": [\n      {\n        \"views\": [\n          {\n            \"name\": \"VIEW NAME\",\n            \"type\": \"FeatureBoardView\",\n            \"settings_str\": \"{}\"\n          }\n        ]\n      }\n    ]\n  },\n  \"account_id\": X\n}\n</code></pre>"
